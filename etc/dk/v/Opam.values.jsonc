                        "OCAML=$(--path=absnative get-object CommonsLang_OCaml.Base@5.5.0 -s Release.Windows_x86_64 -d :)${/}bin${/}ocaml.exe",
                        "OCAMLDEP=$(--path=absnative get-object CommonsLang_OCaml.Base@5.5.0 -s Release.Windows_x86_64 -d :)${/}bin${/}ocamldep.exe",
                        "OCAMLMKTOP=$(--path=absnative get-object CommonsLang_OCaml.Base@5.5.0 -s Release.Windows_x86_64 -d :)${/}bin${/}ocamlmktop.exe",
                        "OCAMLMKLIB=$(--path=absnative get-object CommonsLang_OCaml.Base@5.5.0 -s Release.Windows_x86_64 -d :)${/}bin${/}ocamlmklib.exe",
                        "DUNE=$(--path=absnative get-object CommonsLang_OCaml.Dune@3.23.1 -s Release.Windows_x86_64 -e bin/dune.exe -d :)${/}bin${/}dune.exe",
                        "CC=$(--path=absnative get-object CommonsBase_GNU.Toolchain.W64dev@2.5.0 -s Release.execution_abi -e bin/x86_64-w64-mingw32-gcc.exe -d :)${/}bin${/}x86_64-w64-mingw32-gcc.exe",
                        "AWK=$(--path=absnative get-object CommonsBase_GNU.Toolchain.W64dev@2.5.0 -s Release.execution_abi -e bin/awk.exe -d :)${/}bin${/}awk.exe",
                        "$(--path=absnative get-object CommonsBase_GNU.Toolchain.W64dev@2.5.0 -s Release.execution_abi -e bin/sh.exe -d :)${/}bin${/}sh.exe",
                        "./configure",
                        "--with-vendored-deps",
                        "--disable-checks",
                        "--prefix=${SLOTABS.Release.Windows_x86_64}"
                    ],
                    [
                        "$(get-object CommonsBase_Std.Coreutils@0.8.0 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
                        "env",
                        "--chdir",
                        "s",
                        "PATH=${CACHEABS}${/}lookup-s;$(--path=absnative get-object CommonsLang_OCaml.Base@5.5.0 -s Release.Windows_x86_64 -d :)${/}bin;$(--path=absnative get-object CommonsLang_OCaml.Dune@3.23.1 -s Release.Windows_x86_64 -d : -e 'bin/*')${/}bin;$(--path=absnative get-object CommonsBase_GNU.Toolchain.W64dev@2.5.0 -s Release.execution_abi -d : -e 'bin/*')${/}bin",
                        "DUNE=$(--path=absnative get-object CommonsLang_OCaml.Dune@3.23.1 -s Release.Windows_x86_64 -e bin/dune.exe -d :)${/}bin${/}dune.exe",
                        "CC=$(--path=absnative get-object CommonsBase_GNU.Toolchain.W64dev@2.5.0 -s Release.execution_abi -e bin/x86_64-w64-mingw32-gcc.exe -d :)${/}bin${/}x86_64-w64-mingw32-gcc.exe",
                        "AWK=$(--path=absnative get-object CommonsBase_GNU.Toolchain.W64dev@2.5.0 -s Release.execution_abi -e bin/awk.exe -d :)${/}bin${/}awk.exe",
                        "SHELL=$(--path=absnative get-object CommonsBase_GNU.Toolchain.W64dev@2.5.0 -s Release.execution_abi -e bin/sh.exe -d :)${/}bin${/}sh.exe",
                        "MAKESHELL=$(--path=absnative get-object CommonsBase_GNU.Toolchain.W64dev@2.5.0 -s Release.execution_abi -e bin/sh.exe -d :)${/}bin${/}sh.exe",
                        "$(--path=absnative get-object CommonsBase_GNU.Toolchain.W64dev@2.5.0 -s Release.execution_abi -e bin/make.exe -d :)${/}bin${/}make.exe",
                        "opam"
                    ],
