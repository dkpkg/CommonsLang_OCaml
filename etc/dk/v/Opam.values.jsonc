                        "MAKE=make",
                        "/bin/sh",
                        "./configure",
                        "--with-vendored-deps",
                        "--disable-checks",
                        "--prefix=${SLOTABS.Release.Linux_x86_64}"
                    ],
                    [
                        "$(get-object CommonsBase_Std.Coreutils@0.8.0 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
                        "env",
                        "--chdir",
                        "s",
                        "/usr/bin/make",
                        "opam"
