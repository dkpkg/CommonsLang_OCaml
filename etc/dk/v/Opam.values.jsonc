                    ],
                    [
                        "$(get-object CommonsBase_Std.Coreutils@0.8.0 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
                        "mkdir",
                        "-p",
                        "${SLOTABS.Release.Windows_x86_64}/bin"
                    ],
                    [
                        "$(get-object CommonsBase_Std.Coreutils@0.8.0 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
                        "cp",
                        "$(--path=absnative get-asset CommonsLang_OCaml.Apparatus.Scripts@1.0.0 -p assets/s -m ./cygpath -f cygpath)",
                        "${CACHEABS}/lookup-s/cygpath"
                    ],
                    [
                        "$(--path=absnative get-object CommonsBase_GNU.Toolchain.W64dev@2.5.0 -s Release.execution_abi -e bin/tar.exe -d :)${/}bin${/}tar.exe",
                        "xzf",
                        "$(get-asset CommonsLang_OCaml.Opam.Bundle@2.5.1 -p 2.5.1.tar.gz -f 2.5.1.tar.gz)",
                        "-C",
                        "s",
                        "--strip-components=1"
                    ],
                    [
                        "$(get-object CommonsBase_Std.Coreutils@0.8.0 -s ${SLOTNAME.Release.execution_abi} -m ./coreutils.exe -f coreutils.exe -e '*')",
                        "env",
                        "--chdir",
                        "s",
                        "PATH=${CACHEABS}${/}lookup-s;$(--path=absnative get-object CommonsBase_GNU.Toolchain.W64dev@2.5.0 -s Release.execution_abi -d : -e 'bin/*')${/}bin",
